<Window x:Class="Przeliterowywacz.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="O programie" SizeToContent="WidthAndHeight" ResizeMode="NoResize" Icon="Iconexpo-Speech-Balloon-Grey-Speech-balloon-white-p.ico">
    <Window.Background>
        <RadialGradientBrush>
            <GradientStop Color="#FF099BEA" Offset="0" />
            <GradientStop Color="#FF166ADA" Offset="0.5" />
            <GradientStop Color="#FF623FD2" Offset="1" />
        </RadialGradientBrush>
    </Window.Background>
    <Grid>
        <Label Name="Label1" Content="Nazwa programu: {0}&#10;Wersja: {1}&#10;Autor: {2}&#10;{3}&#10;Modyfikowanie oraz sprzedawanie tego programu jest surowo zabronione.&#10;Specjalne podziękowania dla Marka Heatha za bibliotekę NAudio &#10;oraz Pawła Firleja (http://pfco.de) za użyczenie głosu do domyślnego &#10;banku mowy." HorizontalAlignment="Center" Margin="0,0,0,0" VerticalAlignment="Top" Foreground="White"/>
        <UniformGrid Columns="2" HorizontalAlignment="Stretch" Margin="0,143,0,11" VerticalAlignment="Top">
            <Button Name="DockButton1" Content="_OK" Width="110" Click="DockButton1_Click"/>
            <Button Name="DockButton2" Content="Strona _WWW" Width="110" Click="DockButton2_Click"/>
        </UniformGrid>
    </Grid>
</Window>
